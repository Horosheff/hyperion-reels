# VideoShorts / Гиперион — локальные секреты (НЕ коммитить)
# Скопируйте в videoshorts.local.env и заполните.

# Обложки Kie (GPT Image 2)
KIE_API_KEY=

# Дзен — канал (публичный id из URL https://dzen.ru/<channel>)
DZEN_CHANNEL_NAME=
DZEN_CHANNEL_URL=

# Опционально: логин/пароль Яндекса (обычно достаточно «Войти в Дзен» в Results UI → cookies)
# DZEN_LOGIN=
# DZEN_PASSWORD=

# Пути по умолчанию уже внутри плагина — переопределяйте только если нужно:
# VIDEOSHORTS_DZEN_CLIENT=scripts/dzen_client.py
# VIDEOSHORTS_DZEN_CWD=.
# VIDEOSHORTS_DZEN_STORAGE=videoshorts-memory/secrets/dzen_storage_state.json
# STORAGE_STATE=videoshorts-memory/secrets/dzen_storage_state.json
